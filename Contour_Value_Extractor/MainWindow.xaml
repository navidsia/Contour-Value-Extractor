<!-- MainWindow.xaml -->
<Window x:Class="Contour_Value_Extractor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title=""
        Background="#1F1F1F"
        Height="520"
        Width="980"
        WindowStartupLocation="CenterScreen">



    <Window.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#1F1F1F"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#7A0C12"/> 
        <SolidColorBrush x:Key="AccentBrush2" Color="#A0161E"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="InputBrush" Color="#242424"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush2}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="16">
            <StackPanel>

                <TextBlock Text="Contour Value Extractor"
                           FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="TxtStatus"
                           Text="Choose an image to begin."
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" Margin="0,0,0,14"/>

                <Label Content="Minimum value"/>
                <TextBox x:Name="TxtMin" Text="0" />

                <Label Content="Maximum value"/>
                <TextBox x:Name="TxtMax" Text="100" />

                <Label Content="Number of points"/>
                <TextBox x:Name="TxtPoints" Text="200" />

                <Button x:Name="BtnChoose" Content="Choose Image…" Click="BtnChoose_Click"/>
                <Button x:Name="BtnExtract" Content="Extract Data" Click="BtnExtract_Click" IsEnabled="False"/>

                <Button x:Name="BtnOpenFolder" Content="Open Output Folder"
                        Click="BtnOpenFolder_Click" Style="{StaticResource SecondaryButton}" IsEnabled="False"/>

                <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,16,0,12"/>

                <TextBlock Text="Output"
                           FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock x:Name="TxtOutputPath"
                           Text="(no output yet)"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="{StaticResource PanelBrush}" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="10">
            <Grid>
                <StackPanel x:Name="PreviewPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Preview" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose an image to show it here."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer x:Name="PreviewScroll" Visibility="Collapsed">
                    <Border Background="#1A1A1A" CornerRadius="10" Padding="10">
                        <Image x:Name="ImgPreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
</Window>
